    "table",
    "editor.js",
    "editorjs"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "autoprefixer": "^10.5.0",
    "cssnano": "^8.0.1",
    "eslint": "^9.39.4",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vite-plugin-dts": "^5.0.0"
  },
