{
  "name": "@kpvladimir/editorjs-table",
  "description": "Table for Editor.js",
  "version": "2.4.6",
  "packageManager": "npm@11.11.0",
  "license": "MIT",
  "repository": "https://github.com/kpvladimir/editorjs-table",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
